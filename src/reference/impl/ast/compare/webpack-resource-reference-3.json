      "type": "Identifier"
    }
  ],

  "body": {
    "type": "BlockStatement",

    "body": [
      {
        "type": "ExpressionStatement",

        "expression": {
          "type": "AssignmentExpression",

          "operator": "=",

          "left": {
            "type": "MemberExpression",

            "object": {
              "type": "Identifier"
            },

            "property": {
              "type": "Identifier",

              "name": "exports"
            }
          },

          "right": {
            "type": "Literal",

            ";special:name": "resourceReferenceWithPrefix",
            ";special:marker": "value",
            ";special:test": "/^\\/assets\\//"
          }
        }
      }
    ]
  }
}
